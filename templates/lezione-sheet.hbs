<div class="nte-lz-sheet">
  <header class="nte-lz-header">
    <div class="nte-lz-title-wrap">
      <label>TITOLO</label>
      <input class="nte-lz-name" type="text" value="{{item.name}}" placeholder="Titolo della lezione..." />
    </div>
  </header>
  <div class="nte-lz-body">
    <label>TESTO</label>
    <textarea data-field="testo" placeholder="Descrizione della lezione...">{{testo}}</textarea>
  </div>
</div>
