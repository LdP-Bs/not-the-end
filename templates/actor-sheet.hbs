  <!-- SVENTURE + STATI -->
  <div class="nte-bottom">
    <div class="nte-bottom-left">
      <div class="nte-section-title">QUALI SVENTURE MI AFFLIGGONO?</div>
      <div class="nte-sventure">
        {{#each flags.sventure as |s idx|}}
        <div class="nte-sventura">
          <input type="checkbox" class="nte-sv-check" data-flag="sventure.{{idx}}.checked" {{#if s.checked}}checked{{/if}} />
          <input type="text" class="nte-sv-text" data-flag="sventure.{{idx}}.testo" value="{{s.testo}}" placeholder="Sventura {{nte_add idx 1}}" />
        </div>
        {{/each}}
      </div>
    </div>
    <div class="nte-bottom-right">
      <div class="nte-section-title">COSA MI ANNEBBIA LA MENTE?</div>
      <div class="nte-stati">
        <div class="nte-stato confusione">
          <div class="nte-stato-header">
            <span>CONFUSIONE</span>
            <input type="checkbox" class="nte-stato-check" data-flag="confusione.0" {{#if flags.confusione.[0]}}checked{{/if}} />
          </div>
        </div>
        <div class="nte-stato adrenalina">
          <div class="nte-stato-header">
            <span>ADRENALINA</span>
            <input type="checkbox" class="nte-stato-check" data-flag="adrenalina.0" {{#if flags.adrenalina.[0]}}checked{{/if}} />
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- APPUNTI & EQUIP -->
  <div class="nte-extras">
    <div class="nte-extra-field">
      <label>APPUNTI</label>
      <textarea data-flag="appunti" placeholder="Note di gioco...">{{flags.appunti}}</textarea>
    </div>
    <div class="nte-extra-field">
      <label>EQUIPAGGIAMENTO</label>
      <textarea data-flag="equip" placeholder="Oggetti, armi, risorse...">{{flags.equip}}</textarea>
    </div>
  </div>

  <!-- LEZIONI -->
  <div class="nte-lezioni-section">
    <div class="nte-lezioni-header">
      <span class="nte-section-title">LEZIONI</span>
      <button type="button" class="nte-lz-add-btn" data-action="addLezioneSlot">+ Slot</button>
    </div>
    <div class="nte-lezioni" id="nte-lezioni-drop">
      {{#each flags.lezioni as |l idx|}}
      <div class="nte-lezione-slot {{#if l.id}}filled{{/if}}"
           data-slot="{{idx}}"
           data-item-id="{{l.id}}">
        {{#if l.id}}
          <span class="nte-lz-title" title="{{l.testo}}">{{l.nome}}</span>
          <button type="button" class="nte-lz-remove" data-slot="{{idx}}">✕</button>
        {{else}}
          <span class="nte-lz-empty">Trascina una lezione qui</span>
        {{/if}}
      </div>
      {{/each}}
    </div>
  </div>

</div>