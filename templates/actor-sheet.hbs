<div class="nte-sheet">

  <!-- HEADER -->
  <header class="nte-header">
    <img class="nte-avatar" src="{{actor.img}}" data-edit="img" title="{{actor.name}}" />
    <div class="nte-header-fields">
      <input class="nte-name" type="text" value="{{actor.name}}" placeholder="Nome personaggio" />
      <input type="text" data-flag="concetto" value="{{flags.concetto}}" placeholder="Concetto (chi sei in una frase)" class="nte-input-field" />
      <input type="text" data-flag="rischio"  value="{{flags.rischio}}"  placeholder="Per cosa sono disposto a rischiare?" class="nte-input-field nte-rischio" />
    </div>
  </header>

